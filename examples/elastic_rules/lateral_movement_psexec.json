{
  "name": "PsExec Lateral Movement",
  "description": "Detects PsExec service installation indicative of lateral movement",
  "rule_id": "e1003-psexec",
  "type": "eql",
  "language": "eql",
  "severity": "high",
  "risk_score": 73,
  "query": "process where process.name in (\"psexec.exe\", \"psexesvc.exe\")",
  "index": ["winlogbeat-*", "logs-endpoint.events.*"],
  "required_fields": ["process.name", "host.name"],
  "tags": ["Elastic", "Windows"],
  "threat": [
    {
      "framework": "MITRE ATT&CK",
      "tactic": {
        "id": "TA0008",
        "name": "Lateral Movement"
      },
      "technique": [
        {"id": "T1021", "name": "Remote Services"}
      ]
    }
  ],
  "author": ["ODCP Example"],
  "enabled": true
}
